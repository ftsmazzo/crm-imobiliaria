# ===========================================
# FabriaIA CRM Imobiliário – variáveis de ambiente
# Copie para .env e preencha os valores
# ===========================================

# Banco de dados (backend)
DATABASE_URL="postgresql://usuario:senha@localhost:5432/crm_imobiliaria"

# JWT (backend) – gere um segredo forte em produção
JWT_SECRET="altere-um-segredo-longo-e-aleatorio-aqui"
JWT_EXPIRES_IN="7d"

# URL da API (usada pelos front-ends em dev)
# Backend roda em http://localhost:3000
VITE_API_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# CORS (backend) – origens permitidas separadas por vírgula
CORS_ORIGINS="http://localhost:5173,http://localhost:3001"

# Opcional: porta do backend (default 3000)
# PORT=3000

# Evolution API – notificação WhatsApp (imóvel amarelo)
# Se não configurado, o cron não envia mensagens.
# EVOLUTION_API_URL=https://sua-evolution-api.com
# EVOLUTION_INSTANCE=minha-instancia
# EVOLUTION_API_KEY=opcional-apikey

# URL pública do backend do CRM (a API NestJS), para configurar o webhook na Evolution
# NÃO é a URL da Evolution. É a URL em que ESTE backend está acessível (ex.: no EasyPanel).
# A Evolution vai chamar essa URL quando alguém responder no WhatsApp.
# Ex.: https://cmr-imobiliaria-backend.90qhxz.easypanel.host ou https://meu-projeto-backend.90qhxz.easypanel.host
# PUBLIC_BACKEND_URL=
